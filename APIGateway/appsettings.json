{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "customers": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/customers/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/customers/{**catch-all}" }
        ]
      },
      "products": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/products/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/products/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "customers-cluster": {
        "Destinations": {
          "destination": {
            "Address": "http://customerservice:8080/"
          }
        }
      },
      "products-cluster": {
        "Destinations": {
          "destination": {
            "Address": "http://productservice:8080/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
